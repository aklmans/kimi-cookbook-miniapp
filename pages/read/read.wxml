<view class="page t-{{theme}}">
  <!-- reading progress: ratio of scrolled length, measured on scroll -->
  <view wx:if="{{loaded}}" class="progressbar" style="width: {{progress * 100}}%" />

  <!-- skeleton while the chapter is in flight (keyed on `loaded`, not
       `html`: theme/font flushes briefly empty `html` mid-read and must
       not flash the skeleton) -->
  <view wx:if="{{!loaded && !error}}" class="reader">
    <view class="skeleton reader__sk-eyebrow" />
    <view class="skeleton reader__sk-title" />
    <view class="skeleton reader__sk-lede" />
    <view class="skeleton reader__sk-line" />
    <view class="skeleton reader__sk-line" />
    <view class="skeleton reader__sk-line reader__sk-line--short" />
    <view class="skeleton reader__sk-line" />
    <view class="skeleton reader__sk-line" />
  </view>

  <view wx:elif="{{error}}" class="state">
    <view class="state__text">{{error}}</view>
    <button class="btn" hover-class="btn--hover" bindtap="loadChapter">重试</button>
  </view>

  <block wx:else>
    <view class="reader">
      <mp-html
        id="mp-html"
        content="{{html}}"
        container-style="{{containerStyle}}"
        tag-style="{{tagStyle}}"
        use-anchor="{{true}}"
        scroll-table="{{true}}"
        lazy-load="{{true}}"
        selectable="force"
        bindlinktap="onLinkTap"
        bindimgtap="onImgTap"
      />
    </view>

    <!-- end-of-chapter passage: completion card once the whole book is
         finished, otherwise the usual prev/next passage -->
    <view wx:if="{{bookDone}}" class="endcard hairline">
      <view class="endcard__kicker mono">· 全书完 ·</view>
      <view class="endcard__done-title serif-600">读完了。</view>
      <view class="endcard__done-text">10 章,从长文本到一套 agent 栈——你拿到了整张地图。</view>
      <view class="endcard__actions">
        <button
          class="btn btn--primary endcard__nav"
          style="width: 100%"
          hover-class="btn--hover"
          bindtap="goHome"
        >回到书页</button>
      </view>
      <view class="endcard__row">
        <view class="endcard__link" bindtap="copyBookLink">复制全书链接</view>
        <view class="endcard__link" bindtap="shareBookToAI">给 AI 的全书提示词</view>
      </view>
    </view>

    <view wx:else class="endcard hairline">
      <view class="endcard__kicker mono">· 本章完 ·</view>
      <view class="endcard__actions">
        <button
          wx:if="{{chapter.prev}}"
          class="btn endcard__nav"
          style="width: 100%"
          hover-class="btn--hover"
          bindtap="openPrev"
        >← {{chapter.prev.title}}</button>
        <button
          wx:if="{{chapter.next}}"
          class="btn btn--primary endcard__nav"
          style="width: 100%"
          hover-class="btn--hover"
          bindtap="openNext"
        >{{chapter.next.title}} →</button>
      </view>
      <view class="endcard__row">
        <view class="endcard__link" bindtap="openToc">全部目录</view>
        <view class="endcard__link" bindtap="openShare">分享本章</view>
      </view>
    </view>
  </block>

  <!-- off-screen poster canvas -->
  <canvas
    type="2d"
    id="sharePoster"
    class="offscreen-poster"
    style="width: 750px; height: 940px"
  />

  <!-- in-chapter outline FAB -->
  <view
    wx:if="{{outline.length > 0 && loaded}}"
    class="fab t-{{theme}} {{barHidden ? 'fab--down' : ''}}"
    bindtap="toggleOutline"
  >≡</view>

  <!-- back-to-citation chip, shown after jumping to the references block -->
  <view
    wx:if="{{showReturn}}"
    class="returnchip t-{{theme}} {{barHidden ? 'returnchip--down' : ''}}"
    bindtap="backToRef"
  >↑ 返回引文处</view>

  <!-- restore notice, one tap returns to the chapter's top -->
  <view
    wx:if="{{showRestoreTip}}"
    class="restoretip t-{{theme}} {{barHidden ? 'restoretip--down' : ''}}"
    bindtap="backToTop"
  >已回到上次阅读位置 · <text class="restoretip__action">回开头 ↑</text></view>

  <!-- bottom bar (floating, icon + label) -->
  <view class="barwrap t-{{theme}}">
    <view class="bar {{barHidden ? 'is-hidden' : ''}}">
      <view class="bar__item {{!chapter || !chapter.prev ? 'is-disabled' : ''}}" bindtap="openPrev">
        <view class="bar__icon">←</view>
        <view class="bar__label">上一章</view>
      </view>
      <view class="bar__item" bindtap="toggleFont">
        <view class="bar__icon bar__icon--font">A</view>
        <view class="bar__label">{{fontSize}}px</view>
      </view>
      <view class="bar__item" bindtap="toggleTheme">
        <view class="bar__icon">{{themeIcon}}</view>
        <view class="bar__label">{{themeLabel}}</view>
      </view>
      <view class="bar__item" bindtap="openToc">
        <view class="bar__icon">≡</view>
        <view class="bar__label">目录</view>
      </view>
      <view class="bar__item" bindtap="goHome">
        <view class="bar__icon">⌂</view>
        <view class="bar__label">首页</view>
      </view>
      <view class="bar__item {{!chapter || !chapter.next ? 'is-disabled' : ''}}" bindtap="openNext">
        <view class="bar__icon">→</view>
        <view class="bar__label">下一章</view>
      </view>
    </view>
  </view>
  <view class="bottombar__space" />

  <!-- bottom sheet: outline / footnote -->
  <view wx:if="{{panel}}" class="sheet-mask" bindtap="closePanel" />
  <view class="sheet t-{{theme}} {{panel ? 'is-open' : ''}}">
    <!-- swipe-down grab strip (sheet__head below is swipeable too) -->
    <view class="sheet__grab" bindtouchstart="sheetTouchStart" bindtouchend="sheetTouchEnd" />
    <block wx:if="{{panel === 'outline'}}">
      <view class="sheet__head hairline" bindtouchstart="sheetTouchStart" bindtouchend="sheetTouchEnd">
        <view class="sheet__title eyebrow">— 本章目录</view>
        <view class="sheet__close" bindtap="closePanel">×</view>
      </view>
      <scroll-view scroll-y class="sheet__scroll">
        <view
          wx:for="{{outline}}"
          wx:key="id"
          class="sheet__item sheet__item--lv{{item.level}} {{activeOutlineId === item.id ? 'is-active' : ''}}"
          hover-class="sheet__item--hover"
          data-id="{{item.id}}"
          bindtap="jumpToSection"
        >{{item.title}}</view>
      </scroll-view>
    </block>

    <block wx:if="{{panel === 'footnote' && activeRef}}">
      <view class="sheet__head hairline" bindtouchstart="sheetTouchStart" bindtouchend="sheetTouchEnd">
        <view class="sheet__title eyebrow">— 引用 {{activeRef.id}}</view>
        <view class="sheet__close" bindtap="closePanel">×</view>
      </view>
      <view class="sheet__ref-body">{{activeRef.body}}</view>
      <view class="sheet__ref-actions">
        <view wx:if="{{activeRef.url}}" class="sheet__action" bindtap="copyRefLink">复制链接</view>
        <view class="sheet__action" bindtap="jumpToRefs">全部引用 ↓</view>
      </view>
    </block>

    <block wx:if="{{panel === 'share'}}">
      <view class="sheet__head hairline" bindtouchstart="sheetTouchStart" bindtouchend="sheetTouchEnd">
        <view class="sheet__title eyebrow">— 分享本章</view>
        <view class="sheet__close" bindtap="closePanel">×</view>
      </view>
      <view class="share-actions">
        <button class="btn btn--primary share-actions__main" open-type="share" hover-class="btn--hover">发送给朋友</button>
        <view class="share-actions__row">
          <view class="sheet__action" bindtap="makePoster">生成海报图</view>
          <view class="sheet__action" bindtap="shareToAI">分享给 AI</view>
          <view class="sheet__action" bindtap="copyChapterLink">复制链接</view>
        </view>
        <block wx:if="{{showAiPrompt}}">
          <view class="ai-prompt hairline">
            <view class="ai-prompt__label eyebrow">— 给 AI 的提示词</view>
            <view class="ai-prompt__text">
              <text selectable user-select>{{aiPromptText}}</text>
            </view>
            <view class="share-actions__row ai-prompt__row">
              <view class="sheet__action" bindtap="copyAiPrompt">复制提示词</view>
              <view class="sheet__action" bindtap="closeAiPrompt">收起</view>
            </view>
            <view class="share-actions__hint">粘贴给你常用的 AI 助手, 让它读完这本书陪你继续聊。</view>
          </view>
        </block>
        <view wx:else class="share-actions__hint">海报可长按保存或转发;分享给 AI 会复制一段带 llms.md 链接的提示词,粘贴给你常用的 AI 助手即可。</view>
      </view>
    </block>
  </view>
</view>
