.reader {
  padding: 32rpx 40rpx 48rpx;
}

.state {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 96rpx 48rpx;
}

.state__text {
  color: var(--ink-3);
  font-size: 28rpx;
}

/* skeleton */
.reader__sk-eyebrow {
  width: 160rpx;
  height: 24rpx;
  margin: 24rpx 0 32rpx;
}
.reader__sk-title {
  width: 88%;
  height: 60rpx;
  margin-bottom: 28rpx;
}
.reader__sk-lede {
  width: 100%;
  height: 96rpx;
  margin-bottom: 48rpx;
}
.reader__sk-line {
  width: 100%;
  height: 30rpx;
  margin-bottom: 20rpx;
}
.reader__sk-line--short {
  width: 64%;
  margin-bottom: 40rpx;
}

/* ── end-of-chapter passage ── */
.endcard {
  margin: 0 40rpx;
  padding: 40rpx 0 24rpx;
}

.endcard__kicker {
  text-align: center;
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: var(--ink-3);
  margin-bottom: 40rpx;
}

.endcard__actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.endcard__nav {
  width: 100%;
  justify-content: flex-start;
  font-size: 15px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.endcard__row {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  padding: 16rpx 0 8rpx;
}

.endcard__link {
  font-size: 26rpx;
  color: var(--ink-3);
  text-decoration: underline;
  text-decoration-color: var(--accent);
  text-underline-offset: 6rpx;
  background: none;
  border: none;
  padding: 0;
  line-height: 1.6;
}

.endcard__share::after {
  border: none;
}

/* ── outline FAB ── */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 150rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-bar);
  backdrop-filter: blur(12px);
  border: 1rpx solid var(--border);
  border-radius: 50%;
  font-size: 34rpx;
  color: var(--ink-2);
  z-index: 20;
  transition: bottom 240ms ease;
}

.fab--down {
  bottom: 48rpx;
}

/* ── immersive bottom bar ── */
.bottombar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  border-top: 1rpx solid var(--border);
  background: var(--bg-bar);
  backdrop-filter: blur(14px);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 10;
  transform: translateY(0);
  transition: transform 240ms ease;
}

.bottombar.is-hidden {
  transform: translateY(100%);
}

.bottombar__item {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  color: var(--ink-2);
  font-family: "SF Mono", Menlo, Consolas, monospace;
}

.bottombar__item.is-disabled {
  color: var(--ink-3);
  opacity: 0.5;
}

.bottombar__space {
  height: 110rpx;
}

/* ── bottom sheet ── */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.32);
  z-index: 30;
  animation: sheet-mask-in 180ms ease-out;
}

@keyframes sheet-mask-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 62vh;
  background: var(--bg);
  border-top: 1rpx solid var(--border);
  z-index: 31;
  transform: translateY(100%);
  transition: transform 240ms ease;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.sheet.is-open {
  transform: translateY(0);
}

.sheet__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.sheet__close {
  font-size: 40rpx;
  color: var(--ink-3);
  padding: 0 16rpx;
  line-height: 1;
}

.sheet__scroll {
  max-height: 48vh;
  padding: 0 32rpx 32rpx;
}

.sheet__item {
  padding: 20rpx 0;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--ink);
  border-bottom: 1rpx solid var(--border);
}

.sheet__item--lv2 {
  font-family: "TsangerJinKai02-W05", "Songti SC", "STSong", serif;
  font-weight: 600;
}

.sheet__item--lv3 {
  padding-left: 40rpx;
  color: var(--ink-2);
  font-size: 26rpx;
}

.sheet__item--hover {
  background: var(--code-bg);
}

.sheet__ref-body {
  padding: 16rpx 32rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--ink-2);
}

.sheet__ref-actions {
  display: flex;
  gap: 48rpx;
  padding: 0 32rpx 32rpx;
}

.sheet__action {
  font-size: 26rpx;
  color: var(--ink);
  text-decoration: underline;
  text-decoration-color: var(--accent);
  text-underline-offset: 6rpx;
}
