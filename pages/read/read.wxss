.reader {
  padding: 32rpx 40rpx 48rpx;
}

/* ── top reading progress ── */
.progressbar {
  position: fixed;
  top: 0;
  left: 0;
  height: 4rpx;
  background: var(--accent);
  z-index: 25;
  transition: width 80ms linear;
}

.state {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 96rpx 48rpx;
}

.state__text {
  color: var(--ink-3);
  font-size: 28rpx;
  white-space: pre-wrap;
  text-align: center;
  line-height: 1.7;
}

/* skeleton */
.reader__sk-eyebrow {
  width: 160rpx;
  height: 24rpx;
  margin: 24rpx 0 32rpx;
}
.reader__sk-title {
  width: 88%;
  height: 60rpx;
  margin-bottom: 28rpx;
}
.reader__sk-lede {
  width: 100%;
  height: 96rpx;
  margin-bottom: 48rpx;
}
.reader__sk-line {
  width: 100%;
  height: 30rpx;
  margin-bottom: 20rpx;
}
.reader__sk-line--short {
  width: 64%;
  margin-bottom: 40rpx;
}

/* ── end-of-chapter passage ── */
.endcard {
  margin: 0 40rpx;
  padding: 40rpx 0 24rpx;
}

.endcard__kicker {
  text-align: center;
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: var(--ink-3);
  margin-bottom: 40rpx;
}

.endcard__actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

/* 100% width, single line, arrows outside the text run; margin:0 beats
   the WeChat <button> UA's auto side-margins that shrink the button. */
.endcard__nav {
  width: 100%;
  margin: 0;
  justify-content: flex-start;
  font-size: 15px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.endcard__row {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 0 8rpx;
}

/* book-completion card (replaces the prev/next passage on the last
   chapter once every chapter is finished) */
.endcard__done-title {
  text-align: center;
  font-size: 44rpx;
  line-height: 1.4;
  color: var(--ink);
  margin-bottom: 20rpx;
}

.endcard__done-text {
  text-align: center;
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--ink-2);
  margin-bottom: 40rpx;
}

/* secondary endcard actions as full-width bordered boxes (was underlined
   text links) — friendlier hit targets */
.endcard__box {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 24rpx 0;
  border: 1rpx solid var(--border);
  color: var(--accent);
  font-size: 28rpx;
  /* match .btn's 1.4 (not the page's 1.8) so box buttons and real buttons
     land on the same 88rpx — the "white button looks shorter" bug */
  line-height: 1.4;
}

/* ── outline FAB ── */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 216rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-bar);
  backdrop-filter: blur(12px);
  border: 1rpx solid var(--border);
  border-radius: 50%;
  font-size: 34rpx;
  color: var(--ink-2);
  z-index: 20;
  transition: bottom 240ms ease;
}

.fab--down {
  bottom: 48rpx;
}

/* back-to-citation chip / restore notice (left-side counterpart of the
   outline FAB) */
.returnchip,
.restoretip {
  position: fixed;
  left: 32rpx;
  bottom: 216rpx;
  padding: 16rpx 28rpx;
  background: var(--bg-bar);
  backdrop-filter: blur(12px);
  border: 1rpx solid var(--border);
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--ink-2);
  z-index: 20;
  transition: bottom 240ms ease;
}

.returnchip--down,
.restoretip--down {
  bottom: 48rpx;
}

.restoretip__action {
  color: var(--accent);
}

/* ── floating bottom bar: icon + label ── */
.barwrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 24rpx calc(16rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.bar {
  display: flex;
  border: 1rpx solid var(--border);
  background: var(--bg-bar);
  backdrop-filter: blur(14px);
  padding: 14rpx 0 12rpx;
  transform: translateY(0);
  transition: transform 240ms ease;
}

.bar.is-hidden {
  transform: translateY(calc(100% + 40rpx));
}

.bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.bar__icon {
  font-size: 32rpx;
  line-height: 1;
  color: var(--ink);
}

.bar__icon--font {
  font-size: 26rpx;
  font-weight: 600;
}

.bar__label {
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--ink-3);
}

.bar__item.is-disabled {
  opacity: 0.35;
}

.bottombar__space {
  height: 140rpx;
}

/* share-sheet tab/poster/button styles live in app.wxss (shared with the
   book page); only read-specific sheet parts remain here */

.share__ai {
  padding: 0 32rpx 32rpx;
}

.share__prompt {
  max-height: 320rpx;
  overflow-y: auto;
  border: 1rpx solid var(--border);
  padding: 24rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--ink-2);
  white-space: pre-wrap;
  margin: 28rpx 0 20rpx;
}

/* bottom-sheet frame/grab/close styles live in app.wxss */

.sheet__scroll {
  max-height: 48vh;
  padding: 0 32rpx 32rpx;
}

.sheet__item {
  padding: 20rpx 0;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--ink);
  border-bottom: 1rpx solid var(--border);
}

.sheet__item--lv2 {
  font-family: "TsangerJinKai02-W05", "Songti SC", "STSong", serif;
  font-weight: 600;
}

.sheet__item--lv3 {
  padding-left: 40rpx;
  color: var(--ink-2);
  font-size: 26rpx;
}

.sheet__item--hover {
  background: var(--code-bg);
}

/* scroll-spy: the outline entry at the reader's current position */
.sheet__item.is-active {
  color: var(--accent);
  font-weight: 600;
}

.sheet__ref-body {
  padding: 16rpx 32rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--ink-2);
}

.sheet__ref-actions {
  display: flex;
  gap: 48rpx;
  padding: 0 32rpx 32rpx;
}

.sheet__action {
  font-size: 26rpx;
  color: var(--ink);
  text-decoration: underline;
  text-decoration-color: var(--accent);
  text-underline-offset: 6rpx;
}

/* ── reader settings sheet ── */
.settings {
  padding: 8rpx 32rpx 40rpx;
}

.settings__section + .settings__section {
  margin-top: 36rpx;
}

.settings__label {
  margin-bottom: 20rpx;
}

.settings__row {
  display: flex;
  gap: 20rpx;
}

.setopt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  min-height: 112rpx;
  padding: 20rpx 0 14rpx;
  border: 1rpx solid var(--border);
  color: var(--ink-2);
  box-sizing: border-box;
}

.setopt.is-active {
  border-color: var(--accent);
  color: var(--accent);
}

.setopt__glyph {
  line-height: 1.3;
}

.setopt__num {
  font-size: 20rpx;
  color: var(--ink-3);
}

.setopt.is-active .setopt__num {
  color: var(--accent);
}

.setopt__icon {
  font-size: 34rpx;
  line-height: 1;
}

.setopt__name {
  font-size: 24rpx;
}
