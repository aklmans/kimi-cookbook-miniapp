.about {
  padding: 64rpx 48rpx 96rpx;
}

.about__logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 48rpx;
}

.about__title {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--ink);
  margin: 16rpx 0;
}

.about__stop {
  color: var(--accent);
}

.about__lede {
  font-size: 32rpx;
  color: var(--ink-2);
  margin-bottom: 20rpx;
}

.about__bookline {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--ink-3);
  margin-bottom: 48rpx;
}

.about__intro {
  margin-bottom: 48rpx;
}

/* meta grid (读者/方法/形态/语言/订阅/授权) */
.about__meta {
  margin-bottom: 16rpx;
}

.about__meta-row {
  display: flex;
  align-items: baseline;
  gap: 32rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.about__meta-label {
  flex: none;
  width: 128rpx;
}

.about__meta-value {
  font-size: 28rpx;
  color: var(--ink);
}

.about__section {
  padding: 40rpx 0 32rpx;
}

.about__no {
  margin-bottom: 12rpx;
}

.about__h {
  font-size: 40rpx;
  color: var(--ink);
  margin-bottom: 24rpx;
}

.about__p {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--ink-2);
  margin-bottom: 16rpx;
}

/* 怎么读 rows: label + desc + action link */
.about__way {
  margin-bottom: 32rpx;
}

.about__way-label {
  font-size: 30rpx;
  color: var(--ink);
  margin-bottom: 8rpx;
}

.about__license {
  font-size: 26rpx;
  color: var(--ink-3);
}

.about__contacts {
  margin-top: 24rpx;
}

.about__link {
  display: inline-block;
  font-size: 26rpx;
  color: var(--ink);
  text-decoration: underline;
  text-decoration-color: var(--accent);
  text-underline-offset: 6rpx;
  padding: 8rpx 0;
}

.about__kicker {
  margin-top: 80rpx;
  font-size: 36rpx;
  line-height: 1.5;
  color: var(--ink);
}

.about__footer {
  margin-top: 32rpx;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: var(--ink-3);
}
