<view class="page t-{{theme}}">
  <view class="about">
    <image class="about__logo" src="/assets/moon-tile.png" mode="aspectFit" />

    <view class="eyebrow">— 关于本书</view>
    <view class="about__title">关于本书<text class="about__stop">.</text></view>
    <view class="about__lede">{{about.lede}}</view>
    <view class="about__bookline mono">{{about.bookline}}</view>

    <view class="about__p about__intro">{{about.intro}}</view>

    <!-- meta grid -->
    <view class="about__meta hairline">
      <view wx:for="{{about.meta}}" wx:key="label" class="about__meta-row">
        <view class="about__meta-label eyebrow">{{item.label}}</view>
        <view class="about__meta-value">{{item.value}}</view>
      </view>
    </view>

    <view wx:for="{{about.sections}}" wx:key="no" class="about__section hairline">
      <view class="about__no eyebrow">— {{item.no}}</view>
      <view class="about__h serif-600">{{item.title}}<text class="about__stop">.</text></view>

      <view wx:for="{{item.paragraphs}}" wx:for-item="para" wx:key="*this" class="about__p">{{para}}</view>

      <view wx:for="{{item.ways}}" wx:for-item="way" wx:key="label" class="about__way">
        <view class="about__way-label serif-600">{{way.label}}</view>
        <view class="about__p">{{way.text}}</view>
        <view wx:if="{{way.action && way.action.kind === 'toc'}}" class="about__link" bindtap="openToc">{{way.action.label}}</view>
        <view wx:elif="{{way.action && way.action.kind === 'copy'}}" class="about__link" bindtap="copy" data-text="{{way.action.value}}" data-toast="{{way.action.toast}}">{{way.action.label}}</view>
      </view>

      <view wx:if="{{item.license}}" class="about__p about__license">{{item.license}}</view>

      <view wx:if="{{item.contacts}}" class="about__contacts">
        <view wx:for="{{item.contacts}}" wx:for-item="c" wx:key="label" class="about__meta-row">
          <view class="about__meta-label eyebrow">{{c.label}}</view>
          <view class="about__link" bindtap="copy" data-text="{{c.value}}" data-toast="{{c.toast}}">{{c.text}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{about.kicker}}" class="about__kicker serif-600">{{about.kicker}}<text class="about__stop">.</text></view>
    <view class="about__footer mono">KIMI COOKBOOK · NO. 01</view>
  </view>
</view>
