.hero {
  padding: 40rpx 48rpx 96rpx;
}

.masthead {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding-bottom: 24rpx;
  margin-bottom: 32rpx;
  border-bottom: 1rpx solid var(--border);
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: var(--ink-3);
}

.cover-card {
  background: var(--card-ink);
  border-radius: 20rpx;
  height: 460rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  margin-bottom: 56rpx;
}

.cover-card__moon {
  width: 220rpx;
  height: 220rpx;
}

.cover-card__brand {
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 12rpx;
  color: #efe8dc;
}

.hero__eyebrow {
  margin-bottom: 24rpx;
}

.hero__title {
  font-size: 54rpx;
  line-height: 1.35;
  margin-bottom: 28rpx;
  color: var(--ink);
}

.hero__stop {
  color: var(--accent);
}

.hero__lede {
  font-size: 30rpx;
  line-height: 1.75;
  color: var(--ink-2);
  margin-bottom: 56rpx;
}

.hero__stats {
  display: flex;
  gap: 64rpx;
  border-top: 1rpx solid var(--border);
  padding-top: 28rpx;
  margin-bottom: 48rpx;
}

.stat__label {
  margin-bottom: 8rpx;
}

.stat__value {
  font-size: 30rpx;
  color: var(--ink);
}

.hero__actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.hero__cta {
  flex: 1;
}

.hero__progress {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--ink-3);
  margin-bottom: 48rpx;
}

.hero__about {
  font-size: 26rpx;
  color: var(--ink-3);
  text-decoration: underline;
  text-decoration-color: var(--accent);
  text-underline-offset: 6rpx;
}

.state {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 96rpx 48rpx;
}

.state__text {
  color: var(--ink-3);
  font-size: 28rpx;
  white-space: pre-wrap;
  text-align: center;
  line-height: 1.7;
}

/* skeleton */
.hero__sk-cover {
  height: 460rpx;
  border-radius: 20rpx;
  margin: 32rpx 0 56rpx;
}
.hero__sk-eyebrow {
  width: 180rpx;
  height: 24rpx;
  margin-bottom: 32rpx;
}
.hero__sk-title {
  width: 92%;
  height: 64rpx;
  margin-bottom: 20rpx;
}
.hero__sk-title--short {
  width: 55%;
  margin-bottom: 48rpx;
}
.hero__sk-line {
  width: 100%;
  height: 30rpx;
  margin-bottom: 18rpx;
}
.hero__sk-line--short {
  width: 70%;
}
