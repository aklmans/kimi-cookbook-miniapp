<view class="page t-{{theme}}">
  <!-- skeleton while the book payload is in flight -->
  <view wx:if="{{!book && !error}}" class="hero">
    <view class="skeleton hero__sk-cover" />
    <view class="skeleton hero__sk-eyebrow" />
    <view class="skeleton hero__sk-title" />
    <view class="skeleton hero__sk-title hero__sk-title--short" />
    <view class="skeleton hero__sk-line" />
    <view class="skeleton hero__sk-line" />
    <view class="skeleton hero__sk-line hero__sk-line--short" />
  </view>

  <view wx:elif="{{error}}" class="state">
    <view class="state__text">{{error}}</view>
    <button class="btn" bindtap="loadBook">重试</button>
  </view>

  <view wx:else class="hero">
    <view class="masthead">
      <view class="masthead__brand mono">KIMI COOKBOOK</view>
      <view class="masthead__right">
        <view class="masthead__theme" bindtap="toggleTheme">{{themeIcon}}</view>
        <view class="masthead__serial mono">NO. 01</view>
      </view>
    </view>

    <!-- the web cover art (CoverVisual moon scene), rasterized once to a
         local asset via the site repo's dev server + Playwright;
         re-shoot when the brand art changes -->
    <view class="cover-card">
      <image class="cover-card__img" src="/assets/cover.png" mode="aspectFill" />
      <!-- space must live INSIDE the <text> — boundary spaces are collapsed -->
      <view class="cover-card__tag serif-600">Think clearly. Build with<text class="cover-card__tag-hl"> Kimi</text><text class="hero__stop">.</text></view>
    </view>

    <view class="hero__eyebrow eyebrow">— 技术 · 实践</view>
    <view class="hero__title serif-600">
      {{book.coverTitle}}<text class="hero__stop">.</text>
    </view>
    <view class="hero__lede">{{book.lede}}</view>

    <view class="hero__stats">
      <view class="stat">
        <view class="stat__label eyebrow">章节</view>
        <view class="stat__value serif-600">{{book.chapters.length}}</view>
        <view class="stat__desc">约 {{book.readMinutes}} 分钟</view>
      </view>
      <view class="stat">
        <view class="stat__label eyebrow">更新</view>
        <view class="stat__value serif-600">{{book.updated}}</view>
      </view>
      <view class="stat">
        <view class="stat__label eyebrow">作者</view>
        <view class="stat__value serif-600">{{book.author}}</view>
        <view class="stat__desc">写代码,也写字</view>
      </view>
    </view>

    <view class="hero__actions">
      <button class="btn btn--primary hero__cta" hover-class="btn--hover" bindtap="startReading">{{resumeLabel}}</button>
      <button class="btn" hover-class="btn--hover" bindtap="openToc">目录</button>
    </view>

    <view class="hero__foot">
      <view wx:if="{{readCount > 0}}" class="hero__progress mono">已读 {{readCount}} / {{book.chapters.length}}</view>
      <view class="hero__about" bindtap="openShare">分享本书 →</view>
      <view class="hero__about" bindtap="openAbout">关于本书 →</view>
      <view class="hero__colophon mono">DESIGNED BY<text class="hero__colophon-hl"> ZHAPHAR</text> · BUILT BY<text class="hero__colophon-hl"> KIMI CODE</text></view>
    </view>
  </view>

  <!-- off-screen poster canvas -->
  <canvas
    type="2d"
    id="sharePoster"
    class="offscreen-poster"
    style="width: 750px; height: 940px"
  />

  <!-- share sheet (whole-book poster) -->
  <view wx:if="{{panel}}" class="sheet-mask" bindtap="closePanel" />
  <view class="sheet t-{{theme}} {{panel ? 'is-open' : ''}} sheet--tall">
    <view class="sheet__grab" bindtouchstart="sheetTouchStart" bindtouchend="sheetTouchEnd" />
    <view class="sheet__head hairline" bindtouchstart="sheetTouchStart" bindtouchend="sheetTouchEnd">
      <view class="sheet__title eyebrow">— 分享本书</view>
      <view class="sheet__close" bindtap="closePanel">×</view>
    </view>
    <view class="share__friend">
      <scroll-view scroll-y class="share__posterframe">
        <image wx:if="{{posterPath}}" class="share__poster" src="{{posterPath}}" mode="widthFix" />
        <view wx:else class="share__poster-state">{{posterMaking ? '正在画海报…' : '海报生成失败,可关闭后重试'}}</view>
      </scroll-view>
      <view class="share-actions__hint share__hint">存下海报,发给朋友,扫码就能打开。</view>
      <button class="btn btn--primary share__main" open-type="share" hover-class="btn--hover">发送给朋友</button>
      <view class="share__btnrow">
        <view class="share__boxbtn {{!posterPath ? 'is-disabled' : ''}}" bindtap="savePoster">保存海报</view>
        <view class="share__boxbtn" bindtap="copyBookLink">复制链接</view>
        <view class="share__boxbtn" bindtap="closePanel">关闭</view>
      </view>
    </view>
  </view>
</view>
