<view class="page t-{{theme}}">
  <view class="toc-head">
    <view class="eyebrow">— 目录</view>
    <view class="toc-head__title">目录<text class="toc-head__stop">.</text></view>
    <view wx:if="{{book}}" class="toc-head__meta eyebrow">{{book.chapters.length}} 章 · {{book.readMinutes}} 分钟</view>
  </view>

  <view wx:if="{{error}}" class="state">
    <view class="state__text">{{error}}</view>
  </view>

  <view wx:else class="toc-list">
    <view
      wx:for="{{rows.length ? rows : (book ? book.chapters : [])}}"
      wx:key="slug"
      class="toc-row {{item.visited ? 'is-read' : ''}}"
      bindtap="openChapter"
      data-slug="{{item.slug}}"
      hover-class="toc-row--hover"
    >
      <view class="toc-row__num mono">{{item.number}}</view>
      <view class="toc-row__body">
        <view class="toc-row__title">{{item.title}}</view>
        <view class="toc-row__lede">{{item.lede}}</view>
      </view>
      <view class="toc-row__time mono">{{item.readTime}}</view>
    </view>
  </view>
</view>
