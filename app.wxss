/* Design tokens — mirror the site's v3 editorial language
   (warm paper light / ink dark, Kimi blue accent, cool code surface).
   Theme is a class on each page's root view; CSS vars cascade down. */

.t-light {
  --bg: #fafafa;
  --bg-bar: rgba(250, 250, 250, 0.86);
  --ink: #1a1a1a;
  --ink-2: #3a3a3a;
  --ink-3: #6b6b6b;
  --border: #c0bfba;
  --rule: #9a9a9a;
  --accent: #1783ff;
  --code-bg: #f3f6f9;
  --card-ink: #0e0e13;
  --skeleton: #eeece7;
}

.t-dark {
  --bg: #1a1a1a;
  --bg-bar: rgba(26, 26, 26, 0.82);
  --ink: #fafafa;
  --ink-2: #b8b8b8;
  --ink-3: #8a8a8a;
  --border: #3a3a3a;
  --rule: #4a4a4a;
  --accent: #5e9fff;
  --code-bg: #242a32;
  --card-ink: #06080e;
  --skeleton: #262626;
}

/* The site's editorial serif (loaded via wx.loadFontFace at launch),
   stacked ahead of the system CJK serifs it falls back to. */
.page {
  min-height: 100vh;
  background: var(--bg);
  color: var(--ink);
  font-family: "TsangerJinKai02-W04", "Songti SC", "STSong", "Noto Serif SC", serif;
  font-size: 17px;
  line-height: 1.8;
  box-sizing: border-box;
  animation: page-fade-in 180ms ease-out;
}

.serif-600 {
  font-family: "TsangerJinKai02-W05", "Songti SC", "STSong", "Noto Serif SC", serif;
  font-weight: 600;
}

@keyframes page-fade-in {
  from {
    opacity: 0.35;
  }
  to {
    opacity: 1;
  }
}

.mono {
  font-family: "SF Mono", Menlo, Consolas, monospace;
}

/* Shared chrome — the eyebrow / section label pattern (mono, uppercase,
   wide tracking), and the accent stop. */
.eyebrow {
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: var(--ink-3);
}

.hairline {
  border-top: 1rpx solid var(--border);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  border: 1rpx solid var(--ink);
  font-size: 15px;
  line-height: 1.4;
  background: transparent;
  color: var(--ink);
  border-radius: 0;
  transition: opacity 120ms ease, background 120ms ease;
}
.btn--primary {
  background: var(--ink);
  color: var(--bg);
}
.btn--hover,
.btn.button-hover {
  opacity: 0.72;
}
.btn::after {
  border: none;
}

/* Skeleton shimmer — used by every page's loading state. */
.skeleton {
  position: relative;
  overflow: hidden;
  background: var(--skeleton);
  border-radius: 4rpx;
}
.skeleton::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.28), transparent);
  animation: skeleton-sweep 1.2s ease-in-out infinite;
}
@keyframes skeleton-sweep {
  from {
    transform: translateX(-100%);
  }
  to {
    transform: translateX(100%);
  }
}
