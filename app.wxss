/* Design tokens — mirror the site's v3 editorial language
   (warm paper light / ink dark, Kimi blue accent, cool code surface).
   Theme is a class on each page's root view; CSS vars cascade down. */

.t-light {
  --bg: #fafafa;
  --ink: #1a1a1a;
  --ink-2: #3a3a3a;
  --ink-3: #6b6b6b;
  --border: #c0bfba;
  --rule: #9a9a9a;
  --accent: #1783ff;
  --code-bg: #f3f6f9;
  --card-ink: #0e0e13;
}

.t-dark {
  --bg: #1a1a1a;
  --ink: #fafafa;
  --ink-2: #b8b8b8;
  --ink-3: #8a8a8a;
  --border: #3a3a3a;
  --rule: #4a4a4a;
  --accent: #5e9fff;
  --code-bg: #242a32;
  --card-ink: #06080e;
}

.page {
  min-height: 100vh;
  background: var(--bg);
  color: var(--ink);
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
  font-size: 17px;
  line-height: 1.8;
  box-sizing: border-box;
}

.mono {
  font-family: "SF Mono", Menlo, Consolas, monospace;
}

/* Shared chrome — the eyebrow / section label pattern (mono, uppercase,
   wide tracking), and the accent stop. */
.eyebrow {
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: var(--ink-3);
}

.hairline {
  border-top: 1rpx solid var(--border);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  border: 1rpx solid var(--ink);
  font-size: 15px;
  line-height: 1.4;
  background: transparent;
  color: var(--ink);
  border-radius: 0;
}
.btn--primary {
  background: var(--ink);
  color: var(--bg);
}
.btn::after {
  border: none;
}
