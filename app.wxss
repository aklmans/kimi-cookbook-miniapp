/* Design tokens — mirror the site's v3 editorial language
   (warm paper light / ink dark, Kimi blue accent, cool code surface).
   Theme is a class on each page's root view; CSS vars cascade down. */

.t-light {
  --bg: #fafafa;
  --bg-bar: rgba(250, 250, 250, 0.86);
  --ink: #1a1a1a;
  --ink-2: #3a3a3a;
  --ink-3: #6b6b6b;
  --border: #c0bfba;
  --rule: #9a9a9a;
  --accent: #1783ff;
  --code-bg: #f3f6f9;
  --card-ink: #0e0e13;
  --skeleton: #eeece7;
}

.t-dark {
  --bg: #1a1a1a;
  --bg-bar: rgba(26, 26, 26, 0.82);
  --ink: #fafafa;
  --ink-2: #b8b8b8;
  --ink-3: #8a8a8a;
  --border: #3a3a3a;
  --rule: #4a4a4a;
  --accent: #5e9fff;
  --code-bg: #242a32;
  --card-ink: #06080e;
  --skeleton: #262626;
}

/* The site's editorial serif (loaded via wx.loadFontFace at launch),
   stacked ahead of the system CJK serifs it falls back to. */
.page {
  min-height: 100vh;
  background: var(--bg);
  color: var(--ink);
  font-family: "TsangerJinKai02-W04", "Songti SC", "STSong", "Noto Serif SC", serif;
  font-size: 17px;
  line-height: 1.8;
  box-sizing: border-box;
  animation: page-fade-in 180ms ease-out;
}

.serif-600 {
  font-family: "TsangerJinKai02-W05", "Songti SC", "STSong", "Noto Serif SC", serif;
  font-weight: 600;
}

@keyframes page-fade-in {
  from {
    opacity: 0.35;
  }
  to {
    opacity: 1;
  }
}

.mono {
  font-family: "SF Mono", Menlo, Consolas, monospace;
}

/* Shared chrome — the eyebrow / section label pattern (mono, uppercase,
   wide tracking), and the accent stop. */
.eyebrow {
  font-family: "SF Mono", Menlo, Consolas, monospace;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: var(--ink-3);
}

.hairline {
  border-top: 1rpx solid var(--border);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
  min-height: 88rpx;
  padding: 18rpx 32rpx;
  border: 1rpx solid var(--ink);
  font-size: 15px;
  line-height: 1.4;
  background: transparent;
  color: var(--ink);
  border-radius: 0;
  transition: opacity 120ms ease, background 120ms ease;
}
.btn--primary {
  background: var(--ink);
  color: var(--bg);
}
.btn--hover,
.btn.button-hover {
  opacity: 0.72;
}
.btn::after {
  border: none;
}

/* Skeleton shimmer — used by every page's loading state. */
.skeleton {
  position: relative;
  overflow: hidden;
  background: var(--skeleton);
  border-radius: 4rpx;
}
.skeleton::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.28), transparent);
  animation: skeleton-sweep 1.2s ease-in-out infinite;
}
@keyframes skeleton-sweep {
  from {
    transform: translateX(-100%);
  }
  to {
    transform: translateX(100%);
  }
}

/* ── bottom sheet (shared by read + book pages) ── */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.32);
  z-index: 30;
  animation: sheet-mask-in 180ms ease-out;
}

@keyframes sheet-mask-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 62vh;
  background: var(--bg);
  border-top: 1rpx solid var(--border);
  z-index: 31;
  transform: translateY(100%);
  transition: transform 240ms ease;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.sheet.is-open {
  transform: translateY(0);
}

/* the share sheet runs taller: fixed poster frame + visible buttons */
.sheet--tall {
  max-height: 86vh;
}

/* swipe-down grab strip at the sheet's top edge */
.sheet__grab {
  display: flex;
  justify-content: center;
  padding: 14rpx 0 2rpx;
}

.sheet__grab::before {
  content: "";
  width: 64rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: var(--border);
}

.sheet__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.sheet__close {
  font-size: 40rpx;
  color: var(--ink-3);
  padding: 0 16rpx;
  line-height: 1;
}

/* ── share sheet: tabs, poster frame, boxed buttons ── */
.sharetab {
  display: flex;
  gap: 56rpx;
  padding: 4rpx 32rpx 0;
}

.sharetab__item {
  font-size: 32rpx;
  color: var(--ink-3);
  padding: 16rpx 0 14rpx;
  border-bottom: 2rpx solid transparent;
}

.sharetab__item.is-active {
  color: var(--ink);
  border-bottom-color: var(--accent);
}

.share__friend {
  padding: 0 32rpx 32rpx;
}

.share__posterframe {
  height: 44vh;
  border: 1rpx solid var(--border);
  margin: 28rpx 0 20rpx;
}

.share__poster {
  display: block;
  width: 100%;
}

.share__poster-state {
  padding: 120rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: var(--ink-3);
}

.share__hint {
  text-align: center;
  margin-bottom: 28rpx;
}

.share__main {
  width: 100%;
  margin-bottom: 20rpx;
}

.share__btnrow {
  display: flex;
  gap: 20rpx;
}

.share__boxbtn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 22rpx 0;
  border: 1rpx solid var(--border);
  color: var(--accent);
  font-size: 26rpx;
  /* see .endcard__box — 1.4, not the page's 1.8 */
  line-height: 1.4;
}

.share__boxbtn--accent {
  border-color: var(--accent);
}

.share__boxbtn.is-disabled {
  opacity: 0.35;
}

.share-actions__hint {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--ink-3);
}

/* ── off-screen poster canvas (read + book share sheets) ── */
.offscreen-poster {
  position: fixed;
  left: -20000rpx;
  top: 0;
  opacity: 0;
  pointer-events: none;
}
